# Example .env - copy to .env and fill values

# MongoDB (local or Atlas)
MONGO_URL=mongodb://127.0.0.1:27017/homestay
# or ATLAS_DB_URL=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/homestay

# Session secret
SECRET=your-session-secret

# Cloudinary
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-cloud-api-key
CLOUD_API_SECRET=your-cloud-api-secret

# MapTiler
MAPTILER_API_KEY=your-maptile-api-key

# Gemini / Google GenAI (Gemini API key)
GEMINI_API_KEY=your-gemini-api-key
# alternative env name used in some setups:
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Port (optional)
PORT=8080
