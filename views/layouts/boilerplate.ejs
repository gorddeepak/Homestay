<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Homestay</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,600&family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&display=swap" rel="stylesheet">


  <!-- Map -->
  <script src="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.js"></script>
  <link href="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css" rel="stylesheet">

  <!-- Your styles (load last so they override Bootstrap) -->
  <link rel="stylesheet" href="/css/ratings.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- Fevicon -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="homestay" />
  <link rel="manifest" href="/site.webmanifest" />
</head>

<body class="d-flex flex-column min-vh-100">

  <%- include("../includes/navbar.ejs") %>

  <!-- Flash sits outside any container so it can be fixed/full-width -->
  <%- include("../includes/flash.ejs") %>

  <!-- Each page manages its own containers -->
  <%- body %>

  <div id="chatWidget" class="chat-widget">
    <button type="button" id="chatToggleBtn" class="chat-toggle-btn"><i class="bi bi-robot"></i></button>
    <div id="chatBox" class="chat-box" style="display: none;">
      <div class="chat-header">
        <span><i class="bi bi-robot"></i> Ask Homestay AI</span>
        <button type="button" id="chatCloseBtn" class="chat-close-btn">×</button>
      </div>
      <div id="chatWindow" class="chat-window"></div>
      <div class="chat-input-row">
        <input type="text" id="chatInput" class="form-control form-control-brand" placeholder="Ask something...">
        <button type="button" id="chatSendBtn" class="btn btn-earth">Send</button>
      </div>
    </div>
  </div>

  <%- include("../includes/footer.ejs") %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>

</html>