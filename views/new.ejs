<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb</title>
</head>
<body>
    <H3>Create a New Listing:</H3>
    <form method="post" action="/listings">
        <input type="text" name="listing[title]" placeholder="enter title">
        <br><br>
        <textarea name="listing[description]" placeholder="enter description"></textarea>
        <br><br>
        <input type="number" name="listing[price]" placeholder="enter Price">
        <br><br>
        <input type="text" name="listing[image]" placeholder="enter Image link/URL">
        <br><br>
        <input type="text" name="listing[location]" placeholder="enter location">
        <br><br>
        <input type="text" name="listing[country]" placeholder="enter country">
        <br><br>
        <button>Add</button>
    </form>
</body>
</html>