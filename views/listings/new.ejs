<% layout("/layouts/boilerplate") %>

<div class="container py-5" style="max-width: 36rem;">
  <div class="panel-clay p-4 p-md-5 rounded-4">

    <h2 class="fw-bold mb-1 text-earth" style="font-size: 1.75rem;">Create a new listing</h2>
    <p class="mb-4 text-sand" style="font-size: 0.9rem;">Share your space with the world</p>

    <form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Title</label>
        <input id="title" type="text" name="listing[title]" placeholder="e.g. Cozy cabin in the woods" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="my-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Price per night (₹)</label>
        <input type="number" name="listing[price]" placeholder="e.g. 2500" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid price.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Photo</label>
        <input type="file" name="listing[image]" class="form-control form-control-brand">
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Category</label>
        <select name="listing[category]" id="category" class="form-control form-control-brand" required>
          <option value="">Select a category...</option>
          <option value="Mountain Escape">🏔️ Mountain Escape</option>
          <option value="Lakefront Retreat">🏞️ Lakefront Retreat</option>
          <option value="Snowy Peaks">❄️ Snowy Peaks</option>
          <option value="Coastal Haven">🌊 Coastal Haven</option>
          <option value="Woodland Hideaway">🌲 Woodland Hideaway</option>
          <option value="Desert Sanctuary">🏜️ Desert Sanctuary</option>
          <option value="Rural Charm">🌾 Rural Charm</option>
          <option value="Urban Oasis">🌆 Urban Oasis</option>
        </select>
        <div class="invalid-feedback">Please select a category.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Location</label>
        <input type="text" id="location" name="listing[location]" placeholder="e.g. Manali, Himachal Pradesh" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a location.</div>
      </div>

      <div>
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Description</label>
        <textarea id="description" name="listing[description]" placeholder="Describe what makes this place special..." class="form-control form-control-brand" rows="4" required></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a description.</div>
      </div>

      <button type="button" id="generateBtn" class="btn btn-earth mb-3">Generate Description with AI</button>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Country</label>
        <input type="text" name="listing[country]" placeholder="e.g. India" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a country.</div>
      </div>



      <button class="btn btn-earth w-100 py-2 mt-2">Create Listing</button>

    </form>
  </div>
</div>