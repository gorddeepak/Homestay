<% layout("/layouts/boilerplate") %>

<div class="container py-5" style="max-width: 36rem;">
  <div class="panel-clay p-4 p-md-5 rounded-4">

    <h2 class="fw-bold mb-1 text-earth" style="font-size: 1.75rem;">Edit listing</h2>
    <p class="mb-4 text-sand" style="font-size: 0.9rem;">Update the details for your stay</p>

    <form method="post" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data" class="needs-validation" novalidate>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Title</label>
        <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Description</label>
        <textarea name="listing[description]" rows="4" class="form-control form-control-brand" required><%= listing.description %></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a description.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Price per night (₹)</label>
        <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a valid price.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-2">Current photo</label>
        <img src="<%= originalImageUrl %>" alt="current listing image" class="rounded-3 w-100 object-fit-cover" style="height: 12rem;">
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Replace photo (optional)</label>
        <input type="file" name="listing[image]" class="form-control form-control-brand">
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Category</label>
        <select name="listing[category]" class="form-control form-control-brand" required>
          <option value="">Select a category...</option>
          <option value="Mountain Escape" <%= listing.category === 'Mountain Escape'   ? 'selected' : '' %>>🏔️ Mountain Escape</option>
          <option value="Lakefront Retreat" <%= listing.category === 'Lakefront Retreat' ? 'selected' : '' %>>🏞️ Lakefront Retreat</option>
          <option value="Snowy Peaks" <%= listing.category === 'Snowy Peaks'       ? 'selected' : '' %>>❄️ Snowy Peaks</option>
          <option value="Coastal Haven" <%= listing.category === 'Coastal Haven'     ? 'selected' : '' %>>🌊 Coastal Haven</option>
          <option value="Woodland Hideaway" <%= listing.category === 'Woodland Hideaway' ? 'selected' : '' %>>🌲 Woodland Hideaway</option>
          <option value="Desert Sanctuary" <%= listing.category === 'Desert Sanctuary'  ? 'selected' : '' %>>🏜️ Desert Sanctuary</option>
          <option value="Rural Charm" <%= listing.category === 'Rural Charm'       ? 'selected' : '' %>>🌾 Rural Charm</option>
          <option value="Urban Oasis" <%= listing.category === 'Urban Oasis'       ? 'selected' : '' %>>🌆 Urban Oasis</option>
        </select>
        <div class="invalid-feedback">Please select a category.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Location</label>
        <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a location.</div>
      </div>

      <div class="mb-3">
        <label class="form-label-brand text-uppercase fw-bold d-block mb-1">Country</label>
        <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control form-control-brand" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a country.</div>
      </div>

      <button class="btn btn-earth w-100 py-2 mt-2">Save changes</button>

    </form>
  </div>
</div>